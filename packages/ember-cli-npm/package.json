{
  "name": "@embercloud/ember-cli",
  "version": "1.0.0",
  "description": "Ember 官方任务 CLI",
  "bin": {
    "ember": "scripts/run.js"
  },
  "scripts": {
    "postinstall": "node scripts/install.js",
